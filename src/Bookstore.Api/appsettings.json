{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=bookstore;Username=postgres;Password=postgres"
  },
  "Admin": {
    "Username": "admin",
    "Password": "Admin@123"
  },
  "Jwt": {
    "Issuer": "Bookstore.Api",
    "Audience": "Bookstore.Api",
    "SigningKey": "bookstore-api-development-signing-key-123456",
    "ExpirationMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bookstore-api-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
